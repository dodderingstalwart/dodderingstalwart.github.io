---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title>Dodd Blog</title>
	<link href="https://dodderingstalwart.github.io/blog/atom.xml" rel="self" />
	<link href="https://dodderingstalwart.github.io/blog" />
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id>https://dodderingstalwart.github.io/blog</id>
	<author>
		<name> Dodd </name>
		<email> email </email>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="https://dodderingstalwart.github.io/{{ post.url}}"/>
			<updated>{{ post.date | date_to-xmlschema }}</updated>
			<id>https://dodderingstalwart.github.io{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape}}</content>
		</entry>
	{% endfor %}
</feed>
